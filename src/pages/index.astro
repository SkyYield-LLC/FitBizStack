---
import Base from '../layouts/Base.astro';
import NewsletterSignup from '../components/NewsletterSignup.astro';
import { site } from '../config/site';

const featuredReps = [
  {
    no: '001',
    tag: 'Gym Management',
    title: 'Mindbody 2026 — Field Review',
    excerpt: 'Mindbody is still the default for boutique fitness — and the reason most operators eventually look for alternatives. Our team breaks down where it earns its monthly fee, and where it stalls.',
    href: '/reviews/mindbody-review-2026',
    readTime: '14 min',
  },
  {
    no: '002',
    tag: 'Gym Management',
    title: 'Kilo for CrossFit & HIT Studios',
    excerpt: 'Kilo is the platform built for affiliate gyms by an affiliate gym. The membership engine is purpose-built. The trade-off is feature breadth outside the core workflow.',
    href: '/reviews/kilo-review-2026',
    readTime: '11 min',
  },
  {
    no: '003',
    tag: 'Guide',
    title: 'The Fitness Operator Tech Stack',
    excerpt: 'Six categories — gym management, lead capture, retention, programming, payments, comms — and the specific platforms our team specifies for studios scaling from 1 to 5 locations.',
    href: '/guides/best-fitness-tech-stack-2026',
    readTime: '13 min',
  },
];

const formCheck = [
  {
    no: '01',
    title: 'Operator perspective',
    body: 'Every rep is logged by a team that has actually deployed the platform across a coaching floor — not by reviewers reading vendor spec sheets.',
  },
  {
    no: '02',
    title: 'Studio-class workflow',
    body: 'Tools that work for one trainer break at twenty. We measure where each platform breaks the schedule, the membership engine, or the coaching cadence.',
  },
  {
    no: '03',
    title: 'Transparent rate card',
    body: 'Per-member fees, payment processing markup, member-app surcharges — surfaced explicitly so the proposal stops being a surprise mid-quarter.',
  },
];
---
<Base title={site.name} description={site.description}>

  <!-- HERO — performance cover -->
  <section class="hero">
    <div class="hero-grid-overlay"></div>
    <div class="hero-inner container">
      <div class="hero-content">
        <div class="hero-badge" style="font-family:'Barlow Condensed',sans-serif; font-style:italic; font-weight:700; letter-spacing:0.18em; text-transform:uppercase;">
          // Tested by gym operators
        </div>
        <h1 style="font-family:'Barlow Condensed',sans-serif; text-transform:uppercase; letter-spacing:0.01em;">The software stack <em>that holds the floor</em></h1>
        <p class="hero-sub">
          Independent reviews of gym management, retention, and programming platforms —
          written by operators who run sessions, memberships, and member experience.
        </p>
        <div class="hero-actions">
          <a href="/reviews" class="btn btn-teal btn-lg">Run the Reviews →</a>
          <a href="/guides/best-fitness-tech-stack-2026" class="btn btn-outline btn-lg" style="color:#FFFFFF; border-color:rgba(255,255,255,.6); background:rgba(255,255,255,.08);">The Tech Stack</a>
        </div>
      </div>

      <div class="hero-stat-card">
        <div class="hero-stats">
          <div class="stat-item">
            <span class="stat-number">8<em>+</em></span>
            <span class="stat-label">Platforms tested</span>
          </div>
          <div class="stat-divider"></div>
          <div class="stat-item">
            <span class="stat-number">Studio</span>
            <span class="stat-label">Operator focus</span>
          </div>
          <div class="stat-divider"></div>
          <div class="stat-item">
            <span class="stat-number">Independent</span>
            <span class="stat-label">Editorial standard</span>
          </div>
          <div class="stat-divider"></div>
          <div class="stat-item">
            <span class="stat-number">2026</span>
            <span class="stat-label">Programming edition</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- FEATURED REPS -->
  <section class="section">
    <div class="container">
      <div class="section-head">
        <p class="section-label">Featured Reps</p>
        <h2 class="section-title">This edition's heavy lifts</h2>
        <p class="section-sub" style="font-family:'Barlow Condensed',sans-serif; font-style:italic; font-weight:500; letter-spacing:0.06em; opacity:0.78; max-width:42rem; margin-top:0.75rem;">
          Three platforms reviewed in depth — tested against the realities of multi-location studios and high-rep coaching floors.
        </p>
      </div>

      <div class="card-grid">
        {featuredReps.map(rep => (
          <a href={rep.href} class="post-card">
            <div class="post-card-body">
              <div style="display:flex; align-items:baseline; gap:0.85rem; margin-bottom:0.6rem;">
                <span style="font-family:'Barlow Condensed',sans-serif; font-style:italic; font-weight:700; color:#4CAF50; font-size:0.85rem; letter-spacing:0.22em; text-transform:uppercase;">// Rep {rep.no}</span>
                <span class="post-card-tag">{rep.tag}</span>
              </div>
              <h3 style="font-family:'Barlow Condensed',sans-serif; text-transform:uppercase; letter-spacing:0.01em;">{rep.title}</h3>
              <p>{rep.excerpt}</p>
              <div class="post-card-meta">
                <span style="text-transform:uppercase; letter-spacing:0.1em; font-style:italic;">Reading</span>
                <span>·</span>
                <span>{rep.readTime}</span>
              </div>
            </div>
          </a>
        ))}
      </div>

      <div style="text-align:center; margin-top:2.5rem;">
        <a href="/reviews" class="btn btn-outline">Full Programming →</a>
      </div>
    </div>
  </section>

  <!-- FORM CHECK -->
  <section class="section section-alt">
    <div class="container">
      <div class="section-head">
        <p class="section-label">Form Check</p>
        <h2 class="section-title">How {site.name} is programmed</h2>
      </div>

      <div class="feature-grid">
        {formCheck.map(item => (
          <div class="feature-item">
            <div style="font-family:'Barlow Condensed',sans-serif; font-style:italic; font-weight:700; color:#4CAF50; font-size:1.4rem; letter-spacing:0.12em; margin-bottom:0.6rem; text-transform:uppercase;">// SET {item.no}</div>
            <h3 style="font-family:'Barlow Condensed',sans-serif; text-transform:uppercase; letter-spacing:0.02em;">{item.title}</h3>
            <p>{item.body}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- NEWSLETTER -->
  <section class="container" style="padding:clamp(1.5rem,4vw,2rem) clamp(1rem,4vw,1.5rem) clamp(2.5rem,6vw,4rem);">
    <NewsletterSignup
      variant="hero"
      title={`The ${site.name} weekly`}
      description="One weekly programming block — new reviews, new field notes, what is breaking on the floor. No spam."
      ctaLabel="Subscribe"
    />
  </section>

</Base>
